{
  "name": "yummy-payments",
  "version": "1.0.0",
  "description": "Payment Orchestrator service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\""
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "prisma": "^6.8.2",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
