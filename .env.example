PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yummy_payments?schema=public
REDIS_URL=redis://localhost:6379

API_KEY=your-api-key

# Payments
PAYMENT_PROVIDER_MAX_RETRIES=3
IDEMPOTENCY_LOCK_TTL_SECONDS=30
IDEMPOTENCY_RECORD_TTL_SECONDS=86400

# Logging (Pino)
LOG_LEVEL=info
LOG_PRETTY=true
LOG_DESTINATION=stdout
# LOG_FILE=/var/log/yummy-payments/app.log
